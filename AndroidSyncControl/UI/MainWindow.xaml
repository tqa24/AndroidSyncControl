<Window x:Class="AndroidSyncControl.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AndroidSyncControl.UI"
        WindowStartupLocation="CenterScreen"
        xmlns:scrcpy="clr-namespace:TqkLibrary.Scrcpy.Wpf;assembly=TqkLibrary.Scrcpy.Wpf"
        xmlns:ViewModels="clr-namespace:AndroidSyncControl.UI.ViewModels"
        xmlns:st="http://schemas.spicytaco.io/"
        xmlns:Wpfui="clr-namespace:TqkLibrary.WpfUi.UserControls;assembly=TqkLibrary.WpfUi"
        xmlns:ctrl="clr-namespace:AndroidSyncControl.UI.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Android Sync Control" Height="720" Width="1200" MinWidth="800" MinHeight="500"
        Icon="/Resources/appicon.ico"
        FontFamily="Segoe UI" FontSize="13"
        Background="{DynamicResource Brush.Window.Background}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        TextOptions.TextFormattingMode="Display"
        StateChanged="Window_StateChanged">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44" ResizeBorderThickness="6" CornerRadius="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.DataContext>
        <ViewModels:MainWVM/>
    </Window.DataContext>

    <Border x:Name="RootBorder" Background="{DynamicResource Brush.Window.Background}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ============================ TITLE BAR ============================ -->
            <!-- CaptionHeight in WindowChrome makes this whole row the native caption
                 (drag to move, drag-from-maximized to restore, double-click to maximize).
                 Interactive controls opt out via WindowChrome.IsHitTestVisibleInChrome. -->
            <Grid Grid.Row="0" Background="{DynamicResource Brush.TitleBar.Background}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Border Width="26" Height="26" CornerRadius="7" Background="{DynamicResource Brush.Accent}">
                        <TextBlock Text="A" FontWeight="Bold" FontSize="15"
                                   Foreground="{DynamicResource Brush.Accent.Foreground}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Android Sync Control" Margin="10,0,0,0" VerticalAlignment="Center"
                               FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <ComboBox x:Name="cbo_language" Width="120" VerticalAlignment="Center" Margin="0,0,6,0"
                              DisplayMemberPath="Display" SelectionChanged="cbo_language_SelectionChanged"/>
                    <Button x:Name="btn_theme" Style="{StaticResource IconButton}" Click="btn_theme_Click"
                            VerticalAlignment="Center" Margin="0,0,6,0" ToolTip="{DynamicResource Str.Theme.System}">
                        <TextBlock x:Name="themeGlyph" FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE706;"/>
                    </Button>
                    <Button Content="{DynamicResource Str.Btn.About}" Style="{StaticResource PurpleButton}" VerticalAlignment="Center"
                            Margin="0,0,12,0" Click="btn_about_Click"/>

                    <Button Style="{StaticResource WindowControlButton}" Click="btn_min_Click" ToolTip="{DynamicResource Str.Tip.Minimize}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE921;"/>
                    </Button>
                    <Button x:Name="btn_max" Style="{StaticResource WindowControlButton}" Click="btn_max_Click" ToolTip="{DynamicResource Str.Tip.Maximize}">
                        <TextBlock x:Name="maxGlyph" FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE922;"/>
                    </Button>
                    <Button Style="{StaticResource WindowCloseButton}" Click="btn_close_Click" ToolTip="{DynamicResource Str.Tip.Close}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE8BB;"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ============================ TOOLBAR ============================ -->
            <Border Grid.Row="1" Background="{DynamicResource Brush.Surface.Background}"
                    BorderBrush="{DynamicResource Brush.Surface.BorderBrush}" BorderThickness="0,1,0,1"
                    Padding="12,10">
                <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto">
                <st:StackPanel Orientation="Horizontal" Wpfui:Spacing.Horizontal="8" MarginBetweenChildren="6">
                    <TextBlock Text="{DynamicResource Str.Toolbar.Device}" VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text.Secondary}"/>
                    <ComboBox ItemsSource="{Binding DeviceNameList}" SelectedItem="{Binding DeviceNameListSelected}"
                              Width="200" VerticalAlignment="Center" Tag="{DynamicResource Str.Combo.SelectDevice}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Width="96" Content="{DynamicResource Str.Btn.ShowMain}" Style="{StaticResource AccentButton}"
                            x:Name="btn_showMain" Click="btn_showMain_Click"/>
                    <Button Width="100" Content="{DynamicResource Str.Btn.ShowListView}" x:Name="btn_showListView" Click="btn_showListView_Click"/>
                    <Button Width="130" Content="{DynamicResource Str.Btn.ShowAllListView}" x:Name="btn_showAllListView" Click="btn_showAllListView_Click"/>

                    <Border Width="1" Margin="4,2" Background="{DynamicResource Brush.Surface.BorderBrush}"/>

                    <TextBlock Text="{DynamicResource Str.Toolbar.Size}" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                    <Slider x:Name="slider" Maximum="100" Minimum="1" Value="{Binding ViewPercent}" Width="180"
                            VerticalAlignment="Center" ValueChanged="slider_ValueChanged" ToolTip="{Binding ViewPercent}"/>
                    <TextBlock VerticalAlignment="Center" MinWidth="34"
                               Text="{Binding ViewPercent, StringFormat={}{0:0}%}"/>

                    <Border Width="1" Margin="4,2" Background="{DynamicResource Brush.Surface.BorderBrush}"/>

                    <TextBlock Text="{DynamicResource Str.Toolbar.MaxFps}" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text.Secondary}"
                               ToolTip="{DynamicResource Str.Tip.MaxFps}"/>
                    <ctrl:NumericUpDown Width="58" Minimum="0" Maximum="120" Value="{Binding MaxFps}" Increment="1"
                               VerticalAlignment="Center"
                               ToolTip="{DynamicResource Str.Tip.MaxFps}"/>
                    <TextBlock Text="{DynamicResource Str.Toolbar.MaxSize}" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text.Secondary}"
                               ToolTip="{DynamicResource Str.Tip.MaxSize}"/>
                    <ctrl:NumericUpDown Width="68" Minimum="0" Value="{Binding MaxSize}" Increment="8"
                               VerticalAlignment="Center"
                               ToolTip="{DynamicResource Str.Tip.MaxSize}"/>
                    <CheckBox Content="{DynamicResource Str.Toolbar.Gpu}" VerticalAlignment="Center" IsChecked="{Binding UseGpu}"
                              ToolTip="{DynamicResource Str.Tip.Gpu}"/>
                    <CheckBox Content="{DynamicResource Str.Toolbar.Audio}" VerticalAlignment="Center" IsChecked="{Binding IsAudio}"
                              ToolTip="{DynamicResource Str.Tip.Audio}"/>
                </st:StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ============================ CONTENT ============================ -->
            <st:StackPanel Orientation="Horizontal" Grid.Row="2" Margin="12" x:Name="stackPanel"
                           SizeChanged="stackPanel_SizeChanged">
                <Grid VerticalAlignment="Stretch" x:Name="parentMainGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Wpfui:Spacing.Horizontal="8" Margin="0,0,0,8">
                        <Button x:Name="btn_mainRemove" Content="{DynamicResource Str.Btn.Disconnect}" Width="64" Click="btn_mainRemove_Click"/>
                        <TextBlock Text="{Binding DeviceView.DeviceId}" VerticalAlignment="Center"/>
                        <CheckBox Content="{DynamicResource Str.Check.Sync}" VerticalAlignment="Center" IsChecked="{Binding DeviceView.IsSync}"/>
                        <CheckBox Content="{DynamicResource Str.Check.Speaker}" VerticalAlignment="Center" IsChecked="{Binding DeviceView.IsSpeaker}"
                                  ToolTip="{DynamicResource Str.Tip.Speaker}"/>
                    </StackPanel>

                    <Border Grid.Row="1" CornerRadius="10" ClipToBounds="True"
                            Background="{DynamicResource Brush.Surface.Background}"
                            BorderBrush="{DynamicResource Brush.Surface.BorderBrush}" BorderThickness="1">
                        <Grid x:Name="mainGrid" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <scrcpy:ScrcpyControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    Control="{Binding DeviceView.Control}"
                                    IsControl="{Binding DeviceView.IsControl}"
                                    ScrcpyUiView="{Binding DeviceView.ScrcpyUiView}"/>
                        </Grid>
                    </Border>
                </Grid>

                <ListView ItemsSource="{Binding DeviceViews}" Margin="8,0,0,0" st:StackPanel.Fill="Fill">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0" Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid HorizontalAlignment="Left" VerticalAlignment="Top" Height="{Binding Height}" Width="{Binding Width}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6" Wpfui:Spacing.Horizontal="8">
                                    <Button x:Name="btn_Remove" Content="{DynamicResource Str.Btn.Disconnect}" Width="60" Click="btn_Remove_Click"/>
                                    <TextBlock Text="{Binding DeviceId}" VerticalAlignment="Center"/>
                                    <CheckBox Content="{DynamicResource Str.Check.Speaker}" VerticalAlignment="Center" IsChecked="{Binding IsSpeaker}"
                                              ToolTip="{DynamicResource Str.Tip.Speaker}"/>
                                </StackPanel>
                                <Border Grid.Row="1" CornerRadius="8" ClipToBounds="True">
                                    <scrcpy:ScrcpyControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                        IsMouseHandler="True" IsKeyHandler="True"
                                        Control="{Binding Control}" IsControl="{Binding IsControl}" ScrcpyUiView="{Binding ScrcpyUiView}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </st:StackPanel>
        </Grid>
    </Border>
</Window>
